# 复制此文件为 .env 并填写真实值

# ─── MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cloud_disk
DB_USER=root
DB_PASSWORD=your_strong_password

# ─── PostgreSQL（AI 服务用）───────────────────────────────────
PG_PASSWORD=your_pg_password

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=          # 留空表示不设密码

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-very-long-random-secret-key
TOKEN_EXPIRES_HOURS=48

# ─── 初始账号 ─────────────────────────────────────────────────
ASUKA_ADMIN_USERNAME=admin
ASUKA_ADMIN_PASSWORD=replace-with-a-strong-admin-password
ASUKA_GUEST_USERNAME=guest
ASUKA_GUEST_PASSWORD=
ASUKA_GUEST_ENABLED=false

# ─── AI 服务 ──────────────────────────────────────────────────
AI_SERVICE_BASE_URL=http://localhost:8000
AI_SERVICE_KEY=your-internal-api-key
MASTER_TOKEN=your-master-download-token

# ─── 本地存储 ─────────────────────────────────────────────────
ASUKA_LOCAL_ROOT_WHITELIST=/tmp/asuka-file-list

# 注：S3 / 百度网盘等远程驱动的凭据（accessKey/secret、refreshToken 等）
# 在管理端按存储逐个配置，存于 storages.addition（数据库），不走全局环境变量。

# ─── DeepSeek ─────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
